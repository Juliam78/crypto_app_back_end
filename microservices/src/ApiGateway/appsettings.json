{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "avatars-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/avatars/{**catch-all}" }
      },
      "market-route": {
        "ClusterId": "market-cluster",
        "Match": { "Path": "/api/market/{**catch-all}" }
      },
      "portfolio-route": {
        "ClusterId": "portfolio-cluster",
        "Match": { "Path": "/api/portfolios/{**catch-all}" }
      },
      "movements-route": {
        "ClusterId": "trading-cluster",
        "Match": { "Path": "/api/movements/{**catch-all}" }
      },
      "trades-route": {
        "ClusterId": "trading-cluster",
        "Match": { "Path": "/api/trades/{**catch-all}" }
      },
      "errors-route": {
        "ClusterId": "admin-cluster",
        "Match": { "Path": "/api/errors/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "auth": { "Address": "http://auth-service:8080/" } }
      },
      "market-cluster": {
        "Destinations": { "market": { "Address": "http://market-service:8080/" } }
      },
      "portfolio-cluster": {
        "Destinations": { "portfolio": { "Address": "http://portfolio-service:8080/" } }
      },
      "trading-cluster": {
        "Destinations": { "trading": { "Address": "http://trading-service:8080/" } }
      },
      "admin-cluster": {
        "Destinations": { "admin": { "Address": "http://admin-service:8080/" } }
      }
    }
  }
}
